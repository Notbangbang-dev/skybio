# ─────────────────────────────────────────────────────────────
#  skybio — local development environment
#  Copy to `.env` and fill in. For Docker deploys use .env.docker.example.
# ─────────────────────────────────────────────────────────────

# Postgres connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skybio?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="dev-insecure-secret-change-me"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Discord OAuth (https://discord.com/developers/applications)
# Redirect URL: http://localhost:3000/api/auth/callback/discord
AUTH_DISCORD_ID="your-discord-client-id"
AUTH_DISCORD_SECRET="your-discord-client-secret"

# YOUR Discord user id(s), comma-separated — these accounts become the site
# OWNER (the only ones that can open /admin). Right-click your name in Discord
# with Developer Mode on → "Copy User ID".
BOOTSTRAP_ADMIN_DISCORD_IDS=""

# Uploads
UPLOAD_DIR="uploads"
# Max size of a single uploaded file, in megabytes (backgrounds/music/video).
MAX_UPLOAD_MB="100"
