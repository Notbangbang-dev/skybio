# ─────────────────────────────────────────────────────────────
#  skybio — Docker Compose environment
#  Copy to `.env` next to docker-compose.yml and fill it in:
#      cp .env.docker.example .env
#
#  NOTE: DATABASE_URL is injected by docker-compose.yml (it points at the `db`
#  service), so you do NOT set it here.
# ─────────────────────────────────────────────────────────────

# --- Database ----------------------------------------------------------------
# Password for the bundled Postgres container.
POSTGRES_PASSWORD="change-me-strong-password"

# --- Auth.js -----------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Public HTTPS URL of the deployment (no trailing slash).
AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# --- Discord OAuth -----------------------------------------------------------
# Redirect URL: https://your-domain.com/api/auth/callback/discord
AUTH_DISCORD_ID="your-discord-client-id"
AUTH_DISCORD_SECRET="your-discord-client-secret"

# --- Owner -------------------------------------------------------------------
# YOUR Discord user id(s), comma-separated. These accounts become the site
# OWNER — the only ones that can open /admin and customize the bio.
BOOTSTRAP_ADMIN_DISCORD_IDS="your-discord-user-id"

# --- TLS / nginx (Let's Encrypt via certbot) ---------------------------------
DOMAIN="your-domain.com"
LETSENCRYPT_EMAIL="admin@your-domain.com"

# --- Uploads -----------------------------------------------------------------
UPLOAD_DIR="/app/uploads"
# Max size of a single uploaded file, in megabytes (backgrounds/music/video).
MAX_UPLOAD_MB="100"

# Set to "true" ONLY when Cloudflare is your ingress AND the origin is firewalled
# to Cloudflare ranges — then the real client IP is read from CF-Connecting-IP.
TRUST_CLOUDFLARE="false"
